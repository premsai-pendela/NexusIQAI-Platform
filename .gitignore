# kept outside the production-aligned PDF archive until evaluation approves them.
data/pdfs_staging/
# Pilot document indexing is evaluated in an isolated local Chroma collection.
data/chroma_staging/
# ChromaDB stores the local PDF retrieval index; relational sales facts come
# from the configured Supabase PostgreSQL DATABASE_URL only.
data/chroma_db/
data/chroma_db_local/
data/sales.db
data/nexusiq.db

