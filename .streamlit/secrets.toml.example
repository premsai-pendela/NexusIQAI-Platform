# Streamlit Cloud secrets — copy to .streamlit/secrets.toml locally
# On Streamlit Cloud, paste these key-value pairs in the Secrets editor

GOOGLE_API_KEY = "your_gemini_api_key_here"
GROQ_API_KEY = "your_groq_api_key_here"
# For Streamlit Cloud, use your PostgreSQL connection string:
DATABASE_URL = "postgresql://user:password@host:5432/dbname"
# For local dev only (SQLite fallback):
# DATABASE_URL = "sqlite:///data/sales.db"
CHROMA_PERSIST_DIRECTORY = "./data/chroma_db"
ENVIRONMENT = "production"
LOG_LEVEL = "WARNING"
