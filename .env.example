# ════════════════════════════════════════════════════════════
#  🔑 GOOGLE AI API KEY
# ════════════════════════════════════════════════════════════
# Get your free API key from: https://ai.google.dev
# Click "Get API Key" → "Create API Key"
GOOGLE_API_KEY=your_google_api_key_here

# ════════════════════════════════════════════════════════════
#  🗄️ DATABASE CONFIGURATION (Supabase PostgreSQL)
# ════════════════════════════════════════════════════════════
# Use the same Supabase database as the deployed app. Local SQLite sales
# snapshots are not a supported relational source.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ════════════════════════════════════════════════════════════
#  🤖 MODEL CONFIGURATION (Optional)
# ════════════════════════════════════════════════════════════
# Model for simple queries (fast, cheap)
SIMPLE_MODEL=gemini-2.0-flash-exp

# Model for complex queries (slower, smarter)
COMPLEX_MODEL=gemini-1.5-pro

# ════════════════════════════════════════════════════════════
#  ⚙️ PERFORMANCE TUNING (Optional)
# ════════════════════════════════════════════════════════════
# Maximum query execution time (seconds)
QUERY_TIMEOUT=30

# Maximum rows to return from queries
MAX_ROWS=10000

# Enable detailed logging (true/false)
DEBUG_MODE=false

# ════════════════════════════════════════════════════════════
#  🟩 NVIDIA NIM (Optional cloud fallback tier)
# ════════════════════════════════════════════════════════════
# Free key from https://build.nvidia.com — used when Gemini/Groq quotas exhaust
NVIDIA_API_KEY=your_nvidia_nim_key_here

# Cerebras Inference — OpenAI-compatible last cloud fallback tier (optional).
# Two-tier: fast model for routing/rewrites, reasoning model for synthesis.
CEREBRAS_API_KEY=
CEREBRAS_FAST_MODEL=gemma-4-31b
CEREBRAS_REASONING_MODEL=gpt-oss-120b
